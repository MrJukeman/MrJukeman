    <tspan x="370" y="110" class="keyColor">System.Host</tspan>  : <tspan class="valueColor">London Metropolitan University</tspan>
    <tspan x="370" y="130" class="keyColor">System.Kernel</tspan>: <tspan class="valueColor">Software Engineer</tspan>
    <tspan x="370" y="170" class="keyColor">Languages</tspan>.<tspan class="keyColor">Programming</tspan>: <tspan class="valueColor">HTML, CSS, PHP, JavaScript, TypeScript</tspan>
    <tspan x="370" y="190" class="keyColor">Languages</tspan>.<tspan class="keyColor">Computer</tspan>   : <tspan class="valueColor">NodeJs, Laravel, ExpressJs</tspan>
